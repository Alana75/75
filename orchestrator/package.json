{
  "name": "@ralph/package-orchestrator",
  "version": "1.0.0",
  "description": "Central package registry, client assignment, and access control for the Ralph platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ralph": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build":   "tsc",
    "dev":     "tsx watch src/server.ts",
    "start":   "node dist/server.js",
    "cli":     "tsx src/cli/index.ts",
    "sync":    "tsx src/cli/index.ts packages:sync",
    "db:init": "tsx src/storage/migrate.ts"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "express":        "^4.18.2",
    "cors":           "^2.8.5",
    "helmet":         "^7.1.0",
    "zod":            "^3.22.4",
    "commander":      "^12.0.0",
    "glob":           "^10.3.12",
    "semver":         "^7.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express":        "^4.17.21",
    "@types/cors":           "^2.8.17",
    "@types/node":           "^20.0.0",
    "@types/semver":         "^7.5.8",
    "tsx":                   "^4.7.2",
    "typescript":            "^5.4.5"
  }
}
